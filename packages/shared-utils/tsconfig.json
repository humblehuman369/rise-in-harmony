{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "downlevelIteration": true,
    "lib": ["ES2022"],
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "noEmit": true,
    "paths": {
      "@rih/shared-types": ["../shared-types/src/index.ts"]
    }
  },
  "include": ["src/**/*"]
}
