# Rise In Harmony — environment template
# Copy to .env and fill in values. Never commit real secrets.

NODE_ENV=development
PORT=3000

# Required in production (≥32 characters)
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-chars

# MySQL connection string
DATABASE_URL=mysql://user:password@host:3306/rise_in_harmony

# Optional pool size (default 10)
# DB_POOL_SIZE=10

# Manus / OAuth
VITE_APP_ID=
OAUTH_SERVER_URL=
OWNER_OPEN_ID=

# Bootstrap admins (comma-separated emails, promoted on sign-in)
RIH_ADMIN_EMAILS=you@example.com

# Storage (Manus Forge)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Email (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=hello@riseinharmony.app
APP_URL=https://www.riseinharmony.com

# Stripe web billing (RIH_ prefix — do not use platform STRIPE_* vars)
RIH_STRIPE_SECRET_KEY=
RIH_STRIPE_WEBHOOK_SECRET=

# RevenueCat mobile billing
REVENUECAT_SECRET_KEY=
REVENUECAT_WEBHOOK_SECRET=

# Optional: authorize POST /api/scheduled/* without Manus cron identity
CRON_SECRET=

# Analytics (client)
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com
