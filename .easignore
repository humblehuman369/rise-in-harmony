# EAS upload ignore list.
#
# IMPORTANT: when this file exists, EAS CLI uses it INSTEAD of .gitignore to
# decide which files to upload for cloud builds. It exists so that the bundled
# mobile audio in apps/mobile/assets/sounds/ (gitignored because it's too large
# for the webdev checkpoint system) is still uploaded to EAS — Metro require()s
# those files and the iOS "Bundle JavaScript" phase fails without them.
#
# Everything below mirrors the relevant excludes from .gitignore, minus the
# audio exclusions.

# Dependencies
**/node_modules
.pnpm-store/

# Native dirs are generated by prebuild on the EAS worker — never upload.
# (apps/mobile/ios exists locally from `expo run:ios` and is hundreds of MB.)
apps/mobile/ios
apps/mobile/android
apps/mobile/.expo

# Build outputs
dist/
build/
*.dist
.next
.nuxt
.expo/

# Environment variables
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# IDE / OS
.vscode/
.idea/
.DS_Store
._*

# Logs / caches / temp
*.log
coverage/
.cache/
.parcel-cache
tmp/
temp/
*.tsbuildinfo

# Git internals
.git/

# Webdev artifacts
.webdev/

# Raw purchased audio source packs (large; local only)
references/audio/incoming/
references/audio/processed/

# Web-served audio (comes from Manus storage, not needed for mobile builds)
client/public/sounds/

# Secrets that must not be uploaded
apps/mobile/AuthKey_*.p8
apps/mobile/google-service-account.json
