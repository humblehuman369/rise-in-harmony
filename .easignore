# EAS Build packaging rules.
#
# When .easignore exists, EAS uses it INSTEAD of .gitignore files to decide
# what to upload. This exists because apps/mobile/assets/sounds/.gitignore
# excludes *.mp3/*.wav from Manus's checkpoint system — but those bundled
# audio files (nature loops + alarm_<hz>.wav tones) MUST be uploaded to EAS
# or iOS prebuild fails copying notification sounds. No audio exclusions here.

# Dependencies / VCS
**/node_modules
.git
.pnpm-store

# Native dirs are generated by prebuild on the EAS worker
apps/mobile/ios
apps/mobile/android
apps/mobile/.expo

# Build outputs / caches
dist
build
coverage
.cache
tmp
.webdev

# Secrets — never upload credentials with the project archive
.env
.env.*
*.p8
google-service-account.json

# Noise
*.log
.DS_Store
