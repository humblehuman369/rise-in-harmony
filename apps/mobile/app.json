{
  "expo": {
    "name": "Rise In Harmony",
    "slug": "rise-in-harmony",
    "version": "1.0.1",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "riseharmony",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0B14"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.riseinharmony.app",
      "infoPlist": {
        "UIBackgroundModes": [
          "audio"
        ],
        "NSMicrophoneUsageDescription": "Rise In Harmony does not record audio. This notice is required because the app's audio playback engine includes recording capabilities that the app never uses.",
        "UIRequiresFullScreen": true,
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0B14"
      },
      "package": "com.riseinharmony.app",
      "versionCode": 1,
      "permissions": [
        "android.permission.SCHEDULE_EXACT_ALARM",
        "android.permission.RECEIVE_BOOT_COMPLETED",
        "android.permission.FOREGROUND_SERVICE",
        "android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK",
        "android.permission.WAKE_LOCK",
        "android.permission.VIBRATE",
        "android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#00D4AA",
          "sounds": [
            "./assets/sounds/alarm_174.wav",
            "./assets/sounds/alarm_285.wav",
            "./assets/sounds/alarm_396.wav",
            "./assets/sounds/alarm_417.wav",
            "./assets/sounds/alarm_432.wav",
            "./assets/sounds/alarm_528.wav",
            "./assets/sounds/alarm_639.wav",
            "./assets/sounds/alarm_741.wav",
            "./assets/sounds/alarm_852.wav",
            "./assets/sounds/alarm_963.wav"
          ]
        }
      ],
      [
        "react-native-audio-api",
        {
          "iosBackgroundMode": true,
          "androidForegroundService": true
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "minSdkVersion": 26,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35
          }
        }
      ],
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "917f33c4-3b87-4f19-82ee-2c54125dae47"
      }
    },
    "owner": "humblehuman369",
    "updates": {
      "url": "https://u.expo.dev/917f33c4-3b87-4f19-82ee-2c54125dae47",
      "enabled": true,
      "fallbackToCacheTimeout": 0,
      "checkAutomatically": "ON_LOAD"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
